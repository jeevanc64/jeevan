{
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "eqeqeq": "warn",
    "no-console": "off",
    "semi": ["warn", "always"]
  },
  "globals": {
    "requestAnimationFrame": "readonly",
    "cancelAnimationFrame": "readonly",
    "localStorage": "readonly",
    "alert": "readonly",
    "navigator": "readonly",
    "window": "readonly",
    "document": "readonly"
  }
}
